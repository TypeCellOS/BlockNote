+  const d = delta.create(nodeName, $prosemirrorDelta)
+  d.setAttrs(n.attrs)
+  n.content.content.forEach(c => {
+    d.insert(c.isText ? (c.text ?? []) : [nodeToDelta(c)], marksToFormattingAttributes(c.marks))
+  })
