+
+const _stepToDelta = s.match({ beforeDoc: Node, afterDoc: Node })
+  .if([ReplaceStep, ReplaceAroundStep], (step, { beforeDoc, afterDoc }) => {
+    const oldStart = beforeDoc.resolve(step.from)
