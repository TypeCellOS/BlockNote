+  const schema = tr.doc.type.schema
+  object.forEach(format ?? {}, (v, k) => {
+    if (v == null) {
+      tr.removeNodeMark(pos, schema.marks[k])
+    } else {
+      tr.addNodeMark(pos, schema.mark(k, v))
+    }
+  })
