+              } else {
+                tr.addMark(from, to, schema.mark(k, v))
+              }
+            })
+          }
+          if (i + nOffset < pc.nodeSize) {
+            nOffset += i
+            currPos.i += i
+            i = 0
+          } else {
+            currParentIndex++
+            i -= pc.nodeSize - nOffset
+            currPos.i += pc.nodeSize - nOffset
+            nOffset = 0
+          }
+        } else {
+          object.forEach(op.format ?? {}, (v, k) => {
+            if (v == null) {
