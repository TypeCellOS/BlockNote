+  const d = delta.create($prosemirrorDelta)
+  ns.forEach(n => {
+    d.insert(n.isText ? (n.text ?? []) : [nodeToDelta(n)], marksToFormattingAttributes(n.marks))
+  })
+  return d.done(false)
