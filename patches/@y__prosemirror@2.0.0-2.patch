+    suggestionDoc?: Y.Doc | undefined;
+    mapAttributionToMark?: AttributionMapper | undefined;
+    attributedNodes?: AttributedNodesPredicate | undefined;
+    customCompare?: NodeCompare | undefined;
+}): Plugin;
