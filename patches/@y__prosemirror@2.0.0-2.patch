+        const pc = pchildren[currParentIndex]
+        if (pc === undefined) {
+          throw new Error('[y/prosemirror]: retain operation is out of bounds')
+        }
+        if (pc.isText) {
+          if (op.format != null) {
+            const from = currPos.i
+            const to = currPos.i + math.min(pc.nodeSize - nOffset, i)
+            object.forEach(op.format, (v, k) => {
