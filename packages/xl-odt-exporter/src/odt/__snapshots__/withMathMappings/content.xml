                </draw:frame>
            </text:p>
            <text:p text:style-name="Standard">
                Inline math:
                <draw:frame draw:style-name="BN_S3" text:anchor-type="as-char">
                    <draw:object xlink:href="Object 2/" xlink:type="simple" xlink:show="embed" xlink:actuate="onLoad"></draw:object>
